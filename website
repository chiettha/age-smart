<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Research Study</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f7f7f7;
            color: #333;
            line-height: 1.6;
        }

        header {
            background-color: #005a9e;
            color: white;
            padding: 20px;
            text-align: center;
        }

        h1 {
            font-size: 36px;
        }

        h2 {
            font-size: 28px;
            margin-top: 20px;
        }

        p {
            font-size: 20px;
        }

        .container {
            max-width: 900px;
            margin: auto;
            padding: 20px;
            background: white;
        }

        .image-section img {
            width: 100%;
            height: auto;
            border-radius: 8px;
        }

        .video-section iframe {
            width: 100%;
            height: 400px;
            border: none;
        }

        .link-section a {
            display: inline-block;
            padding: 15px 20px;
            background-color: #0078d4;
            color: white;
            text-decoration: none;
            font-size: 20px;
            border-radius: 6px;
            margin-top: 10px;
        }

        .link-section a:hover {
            background-color: #005a9e;
        }

        footer {
            text-align: center;
            padding: 15px;
            background: #ddd;
            font-size: 16px;
        }
    </style>
</head>
<body>

<header>
    <h1>Research Study</h1>
    <p>Helping improve health and wellbeing</p>
</header>

<div class="container">

    <!-- About the Research -->
    <section>
        <h2>About the Research</h2>
        <p>
            This research study aims to understand how we can improve health outcomes
            for older adults. We are inviting participants to take part in a simple and
            meaningful study that could help future generations.
        </p>
    </section>

    <!-- Graphic Section -->
    <section class="image-section">
        <h2>Study Overview</h2>
        <img src="your-image.jpg" alt="Research study illustration">
        <!-- Replace 'your-image.jpg' with your image file -->
    </section>

    <!-- YouTube Video Section -->
    <section class="video-section">
        <h2>Watch a Short Introduction</h2>
        <iframe 
            src="https://www.youtube.com/embed/YOUR_VIDEO_ID" 
            title="Research Video">
        </iframe>
        <!-- Replace YOUR_VIDEO_ID with your YouTube video ID -->
    </section>

    <!-- External Link Section -->
    <section class="link-section">
        <h2>Learn More or Participate</h2>
        <a href="https://your-study-link.com" target="_blank">
            Go to Study Information
        </a>
        <!-- Replace with your actual link -->
    </section>

</div>

<footer>
    <p>Contact us: research@example.com</p>
</footer>

</body>
</html>
